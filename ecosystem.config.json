{
  "apps": [
    {
      "name": "climb-delivery-api",
      "script": "./dist/main.js",
      "cwd": "/home/deploy/apps/climb-delivery-api/current",
      "instances": 1,
      "exec_mode": "cluster",
      "watch": false,
      "max_memory_restart": "512M",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3000
      },
      "error_file": "/home/deploy/.pm2/logs/climb-delivery-api-error.log",
      "out_file": "/home/deploy/.pm2/logs/climb-delivery-api-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "autorestart": true,
      "max_restarts": 10,
      "min_uptime": "10s",
      "listen_timeout": 3000,
      "kill_timeout": 5000,
      "wait_ready": false,
      "node_args": [
        "--max-old-space-size=512"
      ]
    }
  ]
}
