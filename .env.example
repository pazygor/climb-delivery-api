# ==================================
# DATABASE
# ==================================
DATABASE_URL="mysql://usuario:senha@localhost:3306/nome_do_banco"

# ==================================
# JWT
# ==================================
# Gere uma chave forte com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="sua_chave_secreta_forte_aqui_com_pelo_menos_32_caracteres"
JWT_EXPIRATION="7d"

# ==================================
# APPLICATION
# ==================================
NODE_ENV="production"
PORT=3000
CORS_ORIGIN="https://seudominio.com,https://www.seudominio.com"

# ==================================
# EMAIL (SMTP)
# ==================================
# Configuração para Gmail (ou outro provedor SMTP)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="seu-email@gmail.com"
MAIL_PASSWORD="sua-senha-ou-app-password"
MAIL_FROM="Climb Delivery <seu-email@gmail.com>"

# ==================================
# FRONTEND
# ==================================
# URL do frontend (usado para links em emails de recuperação de senha, etc)
FRONTEND_URL="https://seudominio.com"

# ==================================
# UPLOAD
# ==================================
# Tamanho máximo de arquivo em bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760

# ==================================
# OBSERVAÇÕES
# ==================================
# 1. NUNCA commite este arquivo com valores reais
# 2. No servidor de produção, copie este arquivo para .env e preencha com valores reais
# 3. Proteja o arquivo .env no servidor: chmod 600 .env
# 4. Para Gmail, use App Password ao invés da senha normal
